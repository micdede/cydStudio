{
  "schema_version": "0.1",
  "name": "Claude Code Idle Screen",
  "page": { "bg": "#111111" },
  "datasources": [
    {
      "id": "claude",
      "type": "push",
      "stale_after_sec": 600,
      "fields": ["session_reset_in_sec", "week_reset_in_sec"]
    }
  ],
  "widgets": [
    { "type": "image", "x": 0, "y": 40, "src": "builtin:claude-logo", "max_w": 320, "max_h": 208 },
    {
      "type": "label",
      "id": "cursor",
      "x": 215, "y": 185,
      "text": "▁▁▁▁",
      "font": 24,
      "color": "#D95A12",
      "hidden_when": "blink_off"
    },
    { "type": "line", "x1": 0, "y1": 288, "x2": 320, "y2": 288, "color": "#1B1B1B", "thickness": 1 },
    { "type": "label", "x": 16, "y": 296, "binding": "claude.session_reset_in_sec", "format": "session {duration}", "font": 14, "color": "#888888" },
    { "type": "label", "x": 304, "y": 296, "binding": "claude.week_reset_in_sec", "format": "week {duration}", "font": 14, "color": "#888888", "align": "right" }
  ]
}
