// #define CYDSTUDIO_DEFAULT_WIFI_PSK   "your-password"
// #define CYDSTUDIO_DEFAULT_HOSTNAME   "claude-monitor"
// #define CYDSTUDIO_DEFAULT_OTA_PW     "claude-monitor-ota"
