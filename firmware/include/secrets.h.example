/**
 * Optional compile-time fallback credentials.
 *
 * Copy to firmware/include/secrets.h and fill in your values. Useful when
 * migrating an existing device that's already on a known WiFi — lets you
 * OTA-flash the new firmware without going through the SoftAP provisioning
 * dance. After first boot, the values are persisted to NVS and these
 * defines become irrelevant (NVS wins on subsequent boots).
 *
 * For new devices, leave secrets.h absent and use the SoftAP flow instead.
 */
#pragma once

